root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true

[*.cs]
# Enforce the formatting rule (IDE0055) during build. Combined with
# EnforceCodeStyleInBuild and TreatWarningsAsErrors, formatting violations
# fail the build.
dotnet_diagnostic.IDE0055.severity = warning
