# Normalize line endings for all text files: store as LF in the repository and
# check out as LF on every platform. Backs up the .editorconfig end_of_line = lf rule.
* text=auto eol=lf

# Binary files git must never normalize or treat as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.snk binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
*.snupkg binary
