<RunSettings>
  <DataCollectionRunSettings>
	<DataCollectors>
	  <DataCollector friendlyName="XPlat Code Coverage">
		<Configuration>
		  <Format>cobertura</Format>

		  <!-- Measure only the production library assembly. -->
		  <Include>[Neliva.UidProvider]*</Include>

		  <!-- Never measure the test assembly. -->
		  <Exclude>[Neliva.UidProvider.Tests]*</Exclude>

		  <!-- Honor [ExcludeFromCodeCoverage] and skip compiler-generated code. -->
		  <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>

		  <SkipAutoProps>true</SkipAutoProps>
		  <UseSourceLink>true</UseSourceLink>
		  <DeterministicReport>true</DeterministicReport>
		</Configuration>
	  </DataCollector>
	</DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
